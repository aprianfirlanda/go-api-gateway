FROM golang:1.25.9-alpine AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -ldflags="-s -w" -o /out/control-plane ./cmd/control-plane

FROM alpine:3.22
RUN adduser -D -H appuser
WORKDIR /app
USER appuser
COPY --from=build /out/control-plane /app/control-plane
COPY migrations /app/migrations
EXPOSE 8081
ENTRYPOINT ["/app/control-plane"]
